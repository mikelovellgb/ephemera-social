{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Ephemera",
    "version": "0.1.0",
    "identifier": "social.ephemera.app",
    "build": {
        "frontendDist": "../frontend"
    },
    "app": {
        "windows": [
            {
                "title": "Ephemera",
                "width": 420,
                "height": 800,
                "minWidth": 360,
                "minHeight": 600
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self' mediastream:"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "app", "dmg", "deb", "appimage"],
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
